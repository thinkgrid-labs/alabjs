{
  "name": "alabjs-sync",
  "version": "0.2.1",
  "description": "Local-first sync engine adapters for AlabJS — ElectricSQL, PowerSync, PGlite",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pglite": {
      "import": "./dist/adapters/pglite.js",
      "types": "./dist/adapters/pglite.d.ts"
    },
    "./electric": {
      "import": "./dist/adapters/electric.js",
      "types": "./dist/adapters/electric.d.ts"
    },
    "./powersync": {
      "import": "./dist/adapters/powersync.js",
      "types": "./dist/adapters/powersync.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    },
    "@electric-sql/client": {
      "optional": true
    },
    "@powersync/web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
