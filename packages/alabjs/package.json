{
  "name": "alabjs",
  "version": "0.2.3",
  "description": "AlabJS — full-stack React framework powered by a Rust compiler",
  "keywords": [
    "react",
    "framework",
    "ssr",
    "fullstack",
    "rust",
    "vite",
    "typescript",
    "server-functions",
    "signals",
    "isr"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./router": {
      "import": "./dist/router/index.js",
      "types": "./dist/router/index.d.ts"
    },
    "./router/code": {
      "import": "./dist/router/code-router.js",
      "types": "./dist/router/code-router.d.ts"
    },
    "./test": {
      "import": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    },
    "./signals": {
      "import": "./dist/signals/index.js",
      "types": "./dist/signals/index.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/server/middleware.js",
      "types": "./dist/server/middleware.d.ts"
    },
    "./cache": {
      "import": "./dist/server/cache.js",
      "types": "./dist/server/cache.d.ts"
    },
    "./analytics": {
      "import": "./dist/analytics/store.js",
      "types": "./dist/analytics/store.d.ts"
    },
    "./adapters/cloudflare": {
      "import": "./dist/adapters/cloudflare.js",
      "types": "./dist/adapters/cloudflare.d.ts"
    },
    "./adapters/deno": {
      "import": "./dist/adapters/deno.js",
      "types": "./dist/adapters/deno.d.ts"
    },
    "./adapters/web": {
      "import": "./dist/adapters/web.js",
      "types": "./dist/adapters/web.d.ts"
    }
  },
  "bin": {
    "alab": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "optionalDependencies": {
    "@alabjs/compiler": "workspace:*"
  },
  "dependencies": {
    "h3": "^1.15.0",
    "vite": "^8.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "alabjs-vite-plugin": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^26.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkgrid-labs/alabjs.git"
  },
  "author": "Dennis Paler <dennis@thinkgrid.dev>"
}
